# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── HuggingFace / model artefacts ───────────────────────────────────────────
# Exclude ALL full-model directories (each model.safetensors is ~327 MB and
# the optimizer states are ~655 MB — all well above GitHub's 100 MB limit).
**/fine_tuned_model/
**/fine_tuned_model/*

# Keep ONLY the compact weight-delta file (~4–15 MB, safe for Git).
# Generated by: save_weight_delta() in visual_classifier.py
!**/fine_tuned_model_delta/
!**/fine_tuned_model_delta/**

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Data / cache ─────────────────────────────────────────────────────────────
data/
.cache/
